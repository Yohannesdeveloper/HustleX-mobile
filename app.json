{
  "expo": {
    "name": "HustleX",
    "slug": "hustlex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./public/Logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./public/Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hustlex.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./public/Logo.png",
        "backgroundColor": "#000000"
      },
      "package": "com.hustlex.app",
      "compileSdkVersion": 36,
      "targetSdkVersion": 36,
      "minSdkVersion": 24
    },
    "web": {
      "favicon": "./public/Logo.png",
      "bundler": "metro"
    },
    "scheme": "hustlex",
    "extra": {
      "eas": {
        "projectId": "3e351fc0-c8bb-4f3b-9afe-22f0cb85607d"
      },
      "backendUrl": null
    }
  }
}
